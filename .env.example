# Document Intelligence Refinery — environment variables template.
# Copy this file to .env and set values. Never commit .env with real keys.
# See specs/03-multi-strategy-extraction-engine.md §6.4.

# -----------------------------------------------------------------------------
# LLM Provider (vision extraction + section summarization)
# Supported: openai | deepseek | openrouter | google
# -----------------------------------------------------------------------------

REFINERY_VISION_PROVIDER=openrouter

# Name of the env var that holds the actual API key for the chosen provider.
# Set that var in your shell environment or in .env — never hardcode the key here.
#
# openai    → REFINERY_VISION_API_KEY_ENV=OPENAI_API_KEY    (set OPENAI_API_KEY in shell)
# deepseek  → REFINERY_VISION_API_KEY_ENV=DEEPSEEK_API_KEY  (set DEEPSEEK_API_KEY in shell)
# openrouter→ REFINERY_VISION_API_KEY_ENV=OPENROUTER_API_KEY(set OPENROUTER_API_KEY in shell)
# google    → REFINERY_VISION_API_KEY_ENV=GEMINI_API_KEY    (set GEMINI_API_KEY in shell)

REFINERY_VISION_API_KEY_ENV=OPENAI_API_KEY

# Alternatively, set the key directly (overrides REFINERY_VISION_API_KEY_ENV):
# REFINERY_VISION_API_KEY=

# Optional: override the model used for vision extraction.
# Defaults per provider: openai=gpt-4o-mini, deepseek=deepseek-chat, openrouter=gpt-4o-mini, google=gemini-1.5-flash
# REFINERY_VISION_MODEL=

# Optional: override the model used for section summarization (LLMSummarizer).
# Defaults to the same per-provider default as REFINERY_VISION_MODEL if unset.
# REFINERY_LLM_MODEL=

# -----------------------------------------------------------------------------
# RAG-like semantic search (vector store)
# Optional. When set, LDUs are embedded with this model for semantic retrieval.
# Install: uv sync --extra semantic (sentence-transformers). Re-ingest after enabling.
# -----------------------------------------------------------------------------
REFINERY_EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# LangSmith tracing (query agent, audit)
# Optional. When set, LangGraph and audit runs are traced to LangSmith.
# Get an API key from https://smith.langchain.com and set it in your shell:
#   export LANGSMITH_API_KEY=<your-key>
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=      # set in shell, not here
LANGSMITH_PROJECT=document-intelligence-refinery
