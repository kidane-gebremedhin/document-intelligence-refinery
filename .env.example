# Document Intelligence Refinery — env example.
# Copy to .env and set values. Loaded from project root or cwd.
# See specs/03-multi-strategy-extraction-engine.md §6.4.

# -----------------------------------------------------------------------------
# Vision extraction (Strategy C)
# Used when triage selects vision (e.g. scanned_image). Requires pymupdf for page
# rendering; install with: uv add pymupdf
# -----------------------------------------------------------------------------

# Provider: openai | google
REFINERY_VISION_PROVIDER=openai

# Option B: name of env var that holds the key (set that var in .env or shell)
REFINERY_VISION_API_KEY_ENV=OPENAI_API_KEY

# For Google: use REFINERY_VISION_API_KEY_ENV=GEMINI_API_KEY or set REFINERY_VISION_API_KEY

# -----------------------------------------------------------------------------
# RAG-like semantic search (vector store)
# Optional. When set, LDUs are embedded with this model for semantic retrieval.
# Install: uv sync --extra semantic (sentence-transformers). Re-ingest after enabling.
# -----------------------------------------------------------------------------
REFINERY_EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# LangSmith tracing (query agent, audit)
# Optional. When set, LangGraph and audit runs are traced to LangSmith.
# Get an API key from https://smith.langchain.com
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=<your-langsmith-api-key>
LANGSMITH_PROJECT=document-intelligence-refinery
