# Vision extraction (Strategy C): provider and API key.
# Copy to .env and set values; no code or YAML change needed.
# See specs/03-multi-strategy-extraction-engine.md §6.4.

# Provider: openai | google
REFINERY_VISION_PROVIDER=openai

# Option A: API key directly (recommended for local dev)
# REFINERY_VISION_API_KEY=your-openai-or-google-key

# Option B: name of env var that holds the key (set that var in .env or elsewhere)
REFINERY_VISION_API_KEY_ENV=OPENAI_API_KEY
