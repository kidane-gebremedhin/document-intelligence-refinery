      {
        "id": "sec_0",
        "document_id": "95b06e93627aab6fcdfb83214bda2acd",
        "title": "1.  Introduction",
        "level": 1,
        "page_start": 6,
        "page_end": 6,
        "child_sections": [],
        "key_entities": [],
        "summary": "The introduction of the report estimates federal import tax expenditures for fiscal years 2018/19, 2019/20, and 2020/21, utilizing shipment-level microdata from the Ethiopian Customs Commission. It compares actual tax collections with a benchmark tax system, focusing solely on import taxes due to the availability of relevant data, while noting that future reports should include other tax expenditures. The report builds on previous estimates, highlighting that the estimated revenue forgone on imports was 2.74% of GDP in FY 2018/19, with a revised estimate of 3.7% that may be inflated due to data inconsistencies.",
        "data_types_present": [
          "paragraphs"
        ],
