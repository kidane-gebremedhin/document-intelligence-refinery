      {
        "id": "sec_6",
        "document_id": "95b06e93627aab6fcdfb83214bda2acd",
        "title": "3.3 Data",
        "level": 1,
        "page_start": 15,
        "page_end": 15,
        "child_sections": [],
        "key_entities": [],
        "summary": "The section discusses the data utilized in the report, which comprises shipment-level microdata from the Ethiopian Customs Commission covering FY 2018/19 to FY 2020/21. It highlights the transition from the Automated System for Customs Data to the electronic Customs Management System, resulting in potential double counting of shipments and an overestimation of tax expenditures by up to ETB 30.6 billion for FY 2018/19 and ETB 1.9 billion for FY 2019/20. This issue is crucial for interpreting the results, particularly the trends between the fiscal years.",
        "data_types_present": [
          "paragraphs"
        ],
