      {
        "id": "sec_9",
        "document_id": "95b06e93627aab6fcdfb83214bda2acd",
        "title": "4.2  Customs duty",
        "level": 1,
        "page_start": 22,
        "page_end": 26,
        "child_sections": [],
        "key_entities": [],
        "summary": "In FY 2020/21, Ethiopia's customs duty tax expenditures reached ETB 38.9 billion, marking a 67% increase from ETB 23 billion in FY 2019/20. This growth follows a previous expenditure of ETB 30 billion in FY 2018/19, indicating a significant upward trend in customs duty forgone over the three fiscal years.",
